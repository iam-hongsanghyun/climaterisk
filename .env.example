# climaterisk configuration — copy to .env and adjust. All values have safe defaults.

# --- Orchestration backend (FastAPI) ---
CLIMATERISK_BACKEND_HOST=127.0.0.1
CLIMATERISK_BACKEND_PORT=8099

# --- Frontend (Vite dev server) ---
CLIMATERISK_FRONTEND_PORT=5174

# --- Storage (relative to repo root unless absolute) ---
CLIMATERISK_DATA_DIR=data
CLIMATERISK_LIBRARY_DIR=assets/libraries
# Local hazard catalog (HDF5 + catalog.json). Defaults to <DATA_DIR>/hazard_db.
# CLIMATERISK_HAZARD_DB=data/hazard_db

# --- CLIMADA worker (Phase 2; project-local conda env, never a global one) ---
# Directory of the project-local CLIMADA conda (prefix) env. Build it with:
#   conda env create -f worker/climaterisk_worker/env_climada.yml --prefix ./.climada-env
CLIMATERISK_WORKER_ENV_DIR=.climada-env
# The backend runs `<WORKER_ENV_DIR>/bin/python -m <module> <run_dir>`.
CLIMATERISK_WORKER_MODULE=climaterisk_worker.run_job
# Optional: explicit interpreter path; overrides WORKER_ENV_DIR if set.
# CLIMATERISK_WORKER_PYTHON=
# Max concurrent CLIMADA worker subprocesses (enforced; further submits get HTTP 503).
CLIMATERISK_MAX_WORKERS=2
# Wall-clock cap per worker run (seconds); exceeded runs are killed and reported.
CLIMATERISK_MAX_RUN_SECONDS=900

# --- Optional manual drop-in data (graceful degradation when unset) ---
# Copernicus DEM GeoTIFF (topography) for TC storm-surge (TCSurgeBathtub).
# CLIMATERISK_DEM_PATH=
# EM-DAT disaster-loss CSV (login-gated) for impact-function calibration.
# CLIMATERISK_EMDAT_PATH=

# --- Open-data fetcher (Data tab) ---
# Per-request HTTP read timeout for "Download here" (seconds).
CLIMATERISK_DOWNLOAD_TIMEOUT_SECONDS=180

# --- Logging ---
CLIMATERISK_LOG_LEVEL=INFO
